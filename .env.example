# ============================================================
# Jadarat LMS Environment Variables
# ============================================================

# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (existing)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_ENCRYPTION_KEY=

# ============================================================
# Bunny.net -- Video Streaming CDN (NEW)
# ============================================================
# Get these from: https://dash.bunny.net → Stream → API
BUNNY_API_KEY=                              # Account-level API key (bunny.net dashboard → Account → API Key)
BUNNY_STREAM_API_KEY=                       # Stream Library API key (Stream → Library → API)
BUNNY_STREAM_LIBRARY_ID=                    # Numeric library ID (Stream → Library → Library ID)
BUNNY_STREAM_WEBHOOK_SECRET=                # Set in Stream → Webhooks → Secret
NEXT_PUBLIC_BUNNY_STREAM_HOST=              # e.g., vz-abc123.b-cdn.net (Stream → Library → Hostname)

# ============================================================
# Bunny.net -- Edge Storage for SCORM CDN (NEW)
# ============================================================
# Get these from: https://dash.bunny.net → Storage
BUNNY_STORAGE_KEY=                          # Storage Zone password (Storage → Zone → FTP & API Access → Password)
BUNNY_STORAGE_ZONE=jadarat-scorm            # Storage Zone name
BUNNY_STORAGE_REGION=de                     # Primary region: de (Frankfurt), ny (NYC), la (LA), sg (Singapore)
BUNNY_PULL_ZONE_ID=                         # Pull Zone numeric ID (CDN → Pull Zone → ID)
BUNNY_PULL_ZONE_KEY=                        # Token Authentication key (CDN → Pull Zone → Security → Token Auth)
NEXT_PUBLIC_BUNNY_CDN_HOST=scorm.jadarat.com  # Custom hostname configured on Pull Zone

# ============================================================
# REMOVED -- Do NOT use these anymore
# ============================================================
# COASSEMBLE=                               # REMOVED: Private Coassemble API key
# NEXT_PUBLIC_COASSEMBLE=                   # REMOVED: Public Coassemble API key (was a security risk)
